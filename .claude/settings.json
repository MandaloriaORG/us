{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.agent/hooks/load-context.mjs\"",
            "timeout": 5,
            "statusMessage": "Loading Mandaloria context"
          }
        ]
      }
    ]
  }
}
